#!/bin/bash
#BSUB -W 48:00
#BSUB -n 12
#BSUB -gpu "num=1"
#BSUB -q gpu_l4_large
#BSUB -P johnson
#BSUB -J "dataset[1-26]"
#BSUB -o /groups/johnson/home/doq/analyzeMiceTrajectory/cluster/logs/job_%J_%I.out
#BSUB -e /groups/johnson/home/doq/analyzeMiceTrajectory/cluster/logs/job_%J_%I.err

set -euo pipefail

ARRAY_IDX=$LSB_JOBINDEX
SESSIONS_FILE="$HOME/analyzeMiceTrajectory/cluster/sessions.txt"
SESSION=$(sed -n "${ARRAY_IDX}p" "$SESSIONS_FILE")

if [[ -z "$SESSION" ]]; then
    echo "No session at index $ARRAY_IDX"
    exit 1
fi

ANIMAL=$(echo "$SESSION" | cut -d/ -f1)
VIDEO_FOLDER=$(echo "$SESSION" | cut -d/ -f2)

echo "=== Job $LSB_JOBID[$ARRAY_IDX]: $SESSION ==="
echo "Host: $(hostname)  GPU: $(nvidia-smi --query-gpu=name --format=csv,noheader 2>/dev/null || echo unknown)"

# --- Paths ---
NAS_USER=ratan
NAS_HOST=10.10.1.28
NAS_BASE=/mouse2/climb
# make_dataset.py resolves videos as: video_root / animal / video_folder
# so SCRATCH_ROOT must be the parent, with animal/video_folder beneath it
# Use /scratch/doq if it exists (fast local NVMe), else fall back to /tmp
if [[ -d /scratch/doq && -w /scratch/doq ]]; then
    SCRATCH_ROOT=/scratch/doq/job_$$
elif [[ -w /scratch ]]; then
    mkdir -p /scratch/doq
    SCRATCH_ROOT=/scratch/doq/job_$$
else
    echo "WARNING: /scratch not writable, falling back to /tmp (may be slow for large sessions)"
    SCRATCH_ROOT=/tmp/doq_$$
fi
SCRATCH="$SCRATCH_ROOT/$ANIMAL/$VIDEO_FOLDER"
CODE_DIR=$HOME/analyzeMiceTrajectory
OUTPUT_DIR=$CODE_DIR/dataset

# Activate conda env by prepending its bin to PATH (works reliably in non-interactive jobs)
CONDA_ENV="$HOME/miniconda3/envs/jarvis_repro"
export PATH="$CONDA_ENV/bin:$PATH"
export LD_LIBRARY_PATH="$CONDA_ENV/lib:${LD_LIBRARY_PATH:-}"

# --- 1. Sync video data from NAS to scratch ---
# Stagger rsync starts so all array elements don't hammer the NAS simultaneously.
# Sleep a random 0–119 s (array index sets the seed for reproducibility).
STAGGER=$(( (RANDOM + ARRAY_IDX * 17) % 120 ))
echo "Stagger sleep: ${STAGGER}s (index $ARRAY_IDX)"
sleep "$STAGGER"

echo "[1/4] Syncing $SESSION from NAS to $SCRATCH ..."
mkdir -p "$SCRATCH"
rsync -a \
    "${NAS_USER}@${NAS_HOST}:${NAS_BASE}/${ANIMAL}/${VIDEO_FOLDER}/" \
    "$SCRATCH/" \
    2>&1 | tail -3

echo "Sync complete. Size: $(du -sh "$SCRATCH" | cut -f1)"

# --- 2. TRT skipped on cluster (ir='ts' mode requires cuDNN 8 + system TRT plugins;
#        pip-installed torch_tensorrt 2.5.0 ships cuDNN 9 which is incompatible) ---
echo "[2/4] Skipping TRT (not supported on cluster pip install — using PyTorch models)"

# --- 3. Run predictions ---
echo "[3/4] Running predictions for $SESSION ..."
python3 "$CODE_DIR/make_dataset.py" \
    --session "$SESSION" \
    --video-root "$SCRATCH_ROOT" \
    --trials-dir "$OUTPUT_DIR" \
    --calib-root "$CODE_DIR/calib_params" \
    --output-dir "$OUTPUT_DIR" \
    --no-trt \
    --skip-done \
    2>&1

# --- 4. Clean up scratch ---
echo "[4/4] Cleaning up scratch ..."
rm -rf "$SCRATCH_ROOT"

echo "=== Done: $SESSION ==="
